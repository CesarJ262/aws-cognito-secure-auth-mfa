{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowListFullBucket",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::my-bucket-safe-app"
            ],
            "Condition": {
                "StringLike": {
                    "s3:prefix": [
                        "usuarios/${cognito-identity.amazonaws.com:sub}/*"
                    ]
                }
            }
        },
        {
            "Sid": "AllowFullAccessinOwnFolder",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::my-bucket-safe-app/users/${cognito-identity.amazonaws.com:sub}/*"
            ]
        }
    ]
}